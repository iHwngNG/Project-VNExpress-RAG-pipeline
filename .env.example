# ============================================================================
# RAG Pipeline — Environment Variables
# Copy file này thành .env và sửa giá trị phù hợp
# ============================================================================

# ChromaDB
CHROMA_URL=http://chromadb:8000         # Trong Docker: http://chromadb:8000
                                         # Qua ngrok:    https://xxxx.ngrok-free.app
CHROMA_AUTH_TOKEN=test-token
COLLECTION_NAME=news_articles

# Models
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gemma3:4b

# Ollama
OLLAMA_HOST=http://ollama:11434          # Trong Docker: http://ollama:11434
                                         # Local:        http://localhost:11434
